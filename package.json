{
  "name": "sas-games",
  "displayName": "SAS-games",
  "publisher": "sas-games",
  "description": "",
  "version": "2.1.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:sas.Snake",
    "onCommand:sas.tic-tac-toe",
    "onCommand:sas.gtw",
    "onCommand:sas.memory",
    "onCommand:sas.minesweeper"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sas.Snake",
        "title": "Snake 🐍"
      },
      {
        "command": "sas.memory",
        "title": "Memory Match 🧠"
      },
      {
        "command": "sas.minesweeper",
        "title": "Minesweeper 💣"
      },
      {
        "command": "sas.tic-tac-toe",
        "title": "Tic-tac-toe ❌🔴"
      },
      {
        "command": "sas.gtw",
        "title": "Guess-the-word 🐕"
      }
    ],
    "keybindings":[
      {
        "command": "sas.memory",
        "key": "ctrl+shift+alt+m",
        "when": "editorTextFocus"
      },
      {
        "command": "sas.minesweeper",
        "key": "ctrl+shift+alt+n",
        "when": "editorTextFocus"
      },
      {
        "command": "sas.Snake",
        "key": "ctrl+shift+alt+s",
        "when": "editorTextFocus"
      },
      {
        "command": "sas.tic-tac-toe",
        "key": "ctrl+shift+alt+t",
        "when": "editorTextFocus"
      },
      {
        "command": "sas.gtw",
        "key": "ctrl+shift+alt+g",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
